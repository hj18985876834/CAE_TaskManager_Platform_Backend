# Shared runtime ports
GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
SOLVER_SERVICE_PORT=8082
TASK_SERVICE_PORT=8083
SCHEDULER_SERVICE_PORT=8084
NODE_AGENT_PORT=8085

# Shared database access
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=111111

# Logical schema names for compose service mapping
USER_DB_NAME=user_db
SOLVER_DB_NAME=solver_db
TASK_DB_NAME=task_db
SCHEDULER_DB_NAME=scheduler_db

# Inter-service URLs inside compose network
GATEWAY_BASE_URL=http://gateway-service:8080
USER_SERVICE_BASE_URL=http://user-service:8081
SOLVER_SERVICE_BASE_URL=http://solver-service:8082
TASK_SERVICE_BASE_URL=http://task-service:8083
SCHEDULER_SERVICE_BASE_URL=http://scheduler-service:8084
NODE_AGENT_BASE_URL=http://node-agent:8085

# Gateway route targets
USER_SERVICE_URI=http://user-service:8081
SOLVER_SERVICE_URI=http://solver-service:8082
TASK_SERVICE_URI=http://task-service:8083
SCHEDULER_SERVICE_URI=http://scheduler-service:8084

# Node agent registration address exposed to scheduler
TASK_STORAGE_ROOT=/app/data/tasks
TASK_RESULT_ROOT=/app/node-agent-work
NODE_ADVERTISED_HOST=node-agent:8085
NODE_MAX_CONCURRENCY=2
NODE_WORK_ROOT=/app/node-agent-work
NODE_AGENT_SCHEME=http
